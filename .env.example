# Copy this file to ".env" and fill in your values to use live Riot data.
# Get a key at https://developer.riotgames.com/
# Without a key, the app automatically serves realistic mock data.

RIOT_API_KEY=

# Platform/region defaults (used when the client does not specify one).
# Routing value for match-v5 & account-v1: americas | asia | europe
RIOT_REGIONAL_ROUTE=europe

# Platform for summoner-v4 / league-v4:
# euw1 | eun1 | na1 | kr | br1 | jp1 | la1 | la2 | oc1 | tr1 | ru
RIOT_PLATFORM=eun1

# Server port
PORT=3000
